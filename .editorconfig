# Top-level EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab

# Python files (PEP 8)
[*.py]
indent_size = 4

# Markdown files — allow trailing spaces (used for line breaks)
[*.md]
trim_trailing_whitespace = false
